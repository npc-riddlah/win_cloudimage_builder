				<SynchronousCommand wcm:action="add">
					<CommandLine>REG ADD "HKCU\SOFTWARE\Microsoft\Windows\CurrentVersion\Run" /V "mainhook" /t REG_SZ /F /D "C:\mainhook.cmd"</CommandLine>
